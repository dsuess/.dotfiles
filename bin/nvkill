#!/usr/bin/env bash
# kill_gpu_processes.sh — Kills all processes currently using NVIDIA GPUs.

set -euo pipefail

gpu_filter="${1:-}"

if [[ -n "$gpu_filter" ]]; then
  # Query pid and GPU index, filter to requested GPUs
  pids=$(nvidia-smi --query-compute-apps=pid,gpu_bus_id --id="$gpu_filter" --format=csv,noheader,nounits 2>/dev/null \
    | awk -F',' '{print $1}' | sort -u)
  echo "Filtering to GPU(s): $gpu_filter"
else
  pids=$(nvidia-smi --query-compute-apps=pid --format=csv,noheader,nounits 2>/dev/null | sort -u)
fi

if [[ -z "$pids" ]]; then
  echo "No GPU processes found."
  exit 0
fi

echo "Found GPU processes: $pids"
for pid in $pids; do
  echo "Killing PID $pid ..."
  kill -9 "$pid" 2>/dev/null && echo "  → killed" || echo "  → failed (already exited or permission denied)"
done
