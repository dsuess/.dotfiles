#!/bin/bash

set -e

CPUS=8
MEMORY=32
GPUS=all
CONTAINER_NAME=ai_general_gpu_dev_ds
IMAGE_NAME=ai_general_daniel:latest

while getopts "c:m:g:n:i:" flag
do
    case "${flag}" in
        c) CPUS=${OPTARG};;
        m) MEMORY=${OPTARG};;
        g) GPUS=${OPTARG};;
        n) CONTAINER_NAME=${OPTARG};;
        i) IMAGE_NAME=${OPTARG};;
        \?) echo "Invalid option: -"$OPTARG"" >&2
            exit 1;;
        : ) echo "Option -"$OPTARG" requires an argument." >&2
            exit 1;;
    esac
done

echo "c=$CPUS m=$MEMORY g=$GPUS n=$CONTAINER_NAME"

if [ -z "$CONTAINER_NAME" ];
then
   return -1
fi

if [ "$IMAGE_NAME" == "ai_general_daniel:latest" ];
then
   if [[ -z "${CONDA_TOKEN+x}" ]]
   then
      echo "Please set conda token"
      return -1
   fi

   echo "Building container"
   cd $HOME/.dotfiles/docker
   docker build --build-arg CONDA_TOKEN=${CONDA_TOKEN} -t ai_general_daniel:latest -f dev.Dockerfile .
   cd $HOME
fi

#-p 9999:9999 -p 9998:9998 \

docker run -d \
   --name "${CONTAINER_NAME}" \
   --gpus "${GPUS}" \
   --memory=${MEMORY}g --cpus=$CPUS \
   --network host \
   -e NB_UID=$(id -u) -e NB_GID=$(id -g) -e GRANT_SUDO=yes -e GEN_CERT=yes -e AWS_DEFAULT_REGION=ap-southeast-2 \
   -v /home/NEARMAP.LOCAL/$(id -un):/home/jovyan \
   -v /data:/data \
   -v /mnt/data:/mnt/data \
   -v /home/NEARMAP.LOCAL/daniel.suess/.dotfiles/:/home/NEARMAP.LOCAL/daniel.suess/.dotfiles/ \
   -w /home/jovyan \
   --user root \
   --shm-size=128g \
   -t $IMAGE_NAME start.sh /bin/bash
