[user]
    email = suess.daniel@gmail.com
    name = Daniel Suess
    signingkey = /Users/dsuess/.ssh/id_rsa
[core]
    editor = vim -u ~/.virc
    excludesfile = ~/.gitignore
[init]
	templatedir = /Users/daniel.suess/.git_template
[push]
    default = simple
[merge]
    tool = vimdiff
    conflictstyle = diff3
[difftool]
    prompt = false
[diff]
    tool = vimdiff
[mergetool "vimdiff"]
    cmd = vim -d $BASE $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
[alias]
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
    lv = log --reverse --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
    broom = "! git rm $(git ls-files --deleted)"
[github]
    user = dseuss
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg]
	format = ssh
