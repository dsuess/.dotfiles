[user]
    email = suess.daniel@gmail.com
    name = Daniel Suess
    signingkey = ~/.ssh/id_rsa
[core]
    editor = nvim
    excludesfile = ~/.gitignore
    pager = bat --paging=always
[push]
    default = simple
	autoSetupRemote = true
[merge]
    tool = nvimdiff
    conflictstyle = diff3
[diff]
    tool = bat
[difftool]
    prompt = false

[difftool "bat"]
    cmd = bat -d $LOCAL $REMOTE
[difftool "nvimdiff"]
    cmd = nvim -d $LOCAL $REMOTE
[mergetool "nvimdiff"]
    cmd = nvim -d $BASE $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'

[alias]
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
    lv = log --reverse --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
    broom = "! git rm $(git ls-files --deleted)"
    addnw = !sh -c 'git diff -U0 -w --no-color --src-prefix=a/ --dst-prefix=b/ "$@" | git apply --cached --ignore-whitespace --unidiff-zero -'
[github]
    user = dsuess
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg]
	format = ssh

# To override user/signing on other machines, create ~/.gitconfig.local with:
#   [user]
#       email = your-work-email@company.com
#       name = Your Name
#       signingkey = /path/to/key
#   [commit]
#       gpgsign = false
[include]
    path = ~/.gitconfig.local
[maintenance]
	repo = /Users/danielsuess/work/pytorch
	repo = /Users/danielsuess/work/leo-benchmark
	repo = /Users/danielsuess/work/transformers
	repo = /Users/danielsuess/work/diffusers
	repo = /Users/danielsuess/work/leoframework
	repo = /Users/danielsuess/work/cosmos-curate
	repo = /Users/danielsuess/work/pytorch-lightning
	repo = /Users/danielsuess/work/infinigen
	repo = /Users/danielsuess/work/nunchaku
	repo = /Users/danielsuess/work/Liger-Kernel
	repo = /Users/danielsuess/work/k8s
	repo = /Users/danielsuess/work/leo-train-template
	repo = /Users/danielsuess/work/agent
	repo = /Users/danielsuess/work/leonardo-terraform
	repo = /Users/danielsuess/work/report
	repo = /Users/danielsuess/work/canva
	repo = /Users/danielsuess/work/obs-transcriber
	repo = /Users/danielsuess/work/diffusion-pipe
	repo = /Users/danielsuess/work/botocore
	repo = /Users/danielsuess/work/canva-deps
	repo = /Users/danielsuess/work/claudian
	repo = /Users/danielsuess/work/torchtitan
	repo = /Users/danielsuess/work/s3transfer
[trace2]
	eventtarget = af_unix:dgram:/tmp/olly-git-trace2.sock
	configparams = remote.origin.url
