{
  "enabled": true,
  "network": {
    "allowedDomains": [
      "npmjs.org",
      "*.npmjs.org",
      "registry.npmjs.org",
      "registry.yarnpkg.com",
      "pypi.org",
      "*.pypi.org",
      "github.com",
      "*.github.com",
      "api.github.com",
      "raw.githubusercontent.com"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "~/.ssh",
      "~/.aws",
      "~/.gnupg",
      "~/.kube",
      "~/.netrc",
      "~/.npmrc",
      "~/.pypirc"
    ],
    "allowWrite": [".", "~/.pi", "~/.uv/cache"],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key"],
    "allowGitConfig": true
  }
}
