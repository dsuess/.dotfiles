// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "auto_install_extensions": {
    "zig": true
  },
  "disable_ai": false,
  "ssh_connections": [
    {
      "host": "coder.dev",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/coder"
          ]
        },
        {
          "paths": [
            "/home/coder/work/canva/image2design-utpify"
          ]
        },
        {
          "paths": [
            "/home/coder/work/canva/pawels"
          ]
        },
        {
          "paths": [
            "/home/coder/work/canva/presentation-expert-profiling"
          ]
        },
        {
          "paths": [
            "/home/coder/work/canva/presentation-expert-profiling/design_generation_server/models/presentation_expert_trainer"
          ]
        },
        {
          "paths": [
            "/home/coder/work/sceneforge-3d"
          ]
        }
      ]
    },
    {
      "host": "coder.dev",
      "args": [],
      "projects": []
    }
  ],
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "buffer_line_height": "standard",
  "agent_buffer_font_size": 13.0,
  "agent_ui_font_size": 14.0,
  "status_bar": {
    "show_active_file": false
  },
  "relative_line_numbers": "enabled",
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "agent": {
    "thinking_display": "auto",
    "dock": "left",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "right"
  },
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "session": {
    "trust_all_worktrees": true
  },
  "terminal": {
    "font_family": "AnonymicePro Nerd Font",
    "font_size": 13.0
  },
  "project_panel": {
    "button": true,
    "dock": "right",
    "hide_gitignore": true
  },
  "buffer_font_family": "Fira Code",
  "show_edit_predictions": false,
  "wrap_guides": [
    80
  ],
  "vim_mode": true,
  "load_direnv": "direct",
  "vim": {
    "use_system_clipboard": "on_yank"
  },
  "icon_theme": "Zed (Default)",
  "base_keymap": "VSCode",
  "ui_font_size": 14.0,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "diagnosticMode": "workspace"
        }
      }
    }
  },
}
