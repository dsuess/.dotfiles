{
  "editorMode": "vim",
  "effortLevel": "high",
  "enabledPlugins": {
    "claude-powerline@claude-powerline": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_INSTALLATION_CHECKS": "1"
  },
  "extraKnownMarketplaces": {
    "claude-powerline": {
      "source": {
        "repo": "Owloops/claude-powerline",
        "source": "github"
      }
    },
    "zircote-lsp": {
      "source": {
        "repo": "zircote/lsp-marketplace",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/dsuess/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissions": {
    "allow": ["Bash(cd *)", "Bash(bazel *)"]
  },
  "sandbox": {
    "enabled": true,
    "excludedCommands": ["bazel"],
    "filesystem": {
      "allowRead": [
        ".",
        "~/src",
        "~/.gitconfig",
        "~/.gitconfig.local",
        "~/.dotfiles",
        "~/.cache/uv",
        "~/.local/share/uv"
      ],
      "allowWrite": [
        ".",
        "~/.claude",
        "~/.uv/cache",
        "~/.cache/uv",
        "~/.local/share/uv"
      ],
      "denyRead": ["~/"]
    },
    "network": {}
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  },
  "theme": "dark",
  "tui": "fullscreen",
  "voiceEnabled": true
}
