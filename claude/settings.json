{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_INSTALLATION_CHECKS": "1"
  },
  "permissions": {
    "allow": ["Bash(cd *)", "Bash(bazel *)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '~/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "claude-powerline@claude-powerline": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-powerline": {
      "source": {
        "source": "github",
        "repo": "Owloops/claude-powerline"
      }
    },
    "zircote-lsp": {
      "source": {
        "source": "github",
        "repo": "zircote/lsp-marketplace"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "network": {},
    "filesystem": {
      "allowWrite": [".", "~/.claude", "~/.uv/cache"],
      "denyRead": ["~/"],
      "allowRead": [
        ".",
        "~/src",
        "~/.gitconfig",
        "~/.gitconfig.local",
        "~/.dotfiles"
      ]
    },
    "excludedCommands": ["bazel"]
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "voiceEnabled": true
}
